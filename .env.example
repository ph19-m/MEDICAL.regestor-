DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional server-side auth verification key:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional for local Postgres without SSL:
# PGSSLMODE=disable
# Optional local-only JSON fallback for offline demo work:
# DAWRI_ALLOW_JSON_FALLBACK=true

# Staff/API protection. Change these in Vercel before showing the demo publicly.
STAFF_ACCESS_CODE=clinic-2026
SUPER_ADMIN_ACCESS_CODE=owner-2026
# Keep false in production. If true, STAFF_ACCESS_CODE can see all clinic data.
ALLOW_GLOBAL_STAFF_ACCESS=false
